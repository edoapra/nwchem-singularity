%post
set -ex
 export MPICH_AURORA="4.3.0" 
# export PMIX="4.2.9" 
 export `cat ./fc.txt`
 export `cat ./use_sysv.txt`
 if [ ! -f ./mpi_impl.txt ]; then
     echo MPI_IMPL not defined
     exit 1
 else
     export `cat ./mpi_impl.txt`
     echo MPI_IMPL is $MPI_IMPL
 fi
 if [ $MPI_IMPL = "ompi" ]; then
     if [ ! -f ./ompi.txt ]; then
	 echo OMPI not defined
	 exit 1
     else
	 export `cat ./ompi.txt`
	 echo OMPI is $OMPI
     fi
     export OMPI_DIR=/opt/mpi
     export MPI_DIR=/opt/mpi
     export ompi_prefix=openmpi-$OMPI
     echo ompi_prefix is $ompi_prefix 
     export ompi_major=$(echo $OMPI | cut -d . -f1) 
     echo ompi_major is $ompi_major 
     export ompi_minor=$(echo $OMPI | cut -d . -f2) 
     echo ompi_minor is $ompi_minor 
     echo ompi_major is $ompi_major 
     if [ $ompi_major = '5' ]; then
	 export ompi_options=' --enable-mca-no-build=coll-han '
     else
	 export ompi_options=' --with-pmi --with-pmi-libdir=/usr/lib/x86_64-linux-gnu --without-verbs '
     fi 
     echo ompi_options $ompi_options 
     mpich_major=-1
     mpich_minor=-1
 fi
 if [ $MPI_IMPL = "mpich" ]; then
     if [ ! -f ./mpich.txt ]; then
	 ls -lrt *txt
	 echo MPICH not defined
	 exit 1
     else
	 export `cat ./mpich.txt`
	 echo MPICH is $MPICH
     fi
     export MPICH_DIR=/opt/mpi
     export MPI_DIR=/opt/mpi

     if [ $MPICH = aurora ]; then
	 export MPICH_VERSION=$MPICH_AURORA
     else
	 export MPICH_VERSION=$MPICH
     fi
     if [ ! -f ./mpich_device.txt ]; then
	 echo MPICH_DEVICE not defined
	 exit 1
     else
	 export `cat ./mpich_device.txt`
	 echo MPICH_DEVICE is $MPICH_DEVICE
     fi
     export mpich_prefix=mpich-$MPICH_VERSION
     echo mpich_prefix is $mpich_prefix 
     export mpich_major=$(echo $MPICH_VERSION | cut -d . -f1) 
     echo mpich_major is $mpich_major 
     export mpich_minor=$(echo $MPICH_VERSION | cut -d . -f2) 
     echo mpich_minor is $mpich_minor 
     echo mpich_major is $mpich_major 
     if [ $mpich_major = '4' ]; then
	 export mpich_options=' '
     else
	 export mpich_options=' '
     fi 
     if [ $MPICH = aurora ]; then
	 export mpich_options=$mpich_options' --disable-maintainer-mode --with-pm=no --enable-romio --with-slurm=no --with-pmi=pmix --with-pmix=/opt/mpi '
     fi
     echo mpich_options are $mpich_options
     ompi_major=-1
     ompi_minor=-1
 fi
 if [  -f ./ucx.txt ]; then
     echo cat ucx `cat ./ucx.txt`
     export `cat ./ucx.txt`
     echo UCX is $UCX
     if [ $UCX != "N" ]; then
	 export UCXVTAG=v$UCX 
	 echo standard UCXVTAG is $UCXVTAG 
#	 if [ $UCX = 1.20.0 ]; then export UCXVTAG=$UCX ; fi
	 echo UCX is $UCX UCXVTAG is $UCXVTAG
         export ucx_or_ofi="--enable-mca-no-build=btl-uct --with-ucx="${MPI_DIR}
     fi
 fi
 if [  -f ./ofi.txt ]; then
      export `cat ./ofi.txt`
      echo OFI is $OFI
      if [ $OFI != "N" ]; then
	  export ucx_or_ofi="--with-ofi="${MPI_DIR}
      fi
 fi
 if [ $UCX = "N" ] &&  [ $OFI = "N" ]; then
     echo neither UCX nor OFI defined
     echo exiting
     exit 1
 fi
 if [ $UCX != "N" ] &&  [ $OFI != "N" ]; then
     echo both UCX and OFI are set
     echo exiting
     exit 1
 fi
 if [  -f ./pmix.txt ]; then
      export `cat ./pmix.txt`
      echo PMIX is $PMIX
      if [ $PMIX != "N" ]; then
	  if [ $MPI_IMPL = "mpich" ]; then
	      export pmix_options="--with-pmi=pmix"
	  fi
	  export pmix_options="${pmix_options} --with-pmix=${MPI_DIR}"
      fi
 fi
echo ucx_or_ofi is $ucx_or_ofi
 export `cat ./armci_network.txt`
 export `cat ./cuda_cc.txt` 
 export `cat ./branch.txt`
 export `cat ./myusername.txt`
 echo FC is $FC
 echo CUDA_CC $CUDA_CC 
 echo ARMCI_NETWORK is $ARMCI_NETWORK
 echo USE_SYSV is $USE_SYSV 
 echo MPI_IMPL is $MPI_IMPL
 echo BRANCH is $BRANCH
export DEBIAN_FRONTEND=noninteractive 
export PATH=$MPI_DIR/bin:/opt/intel/oneapi/compiler/latest/bin:/opt/intel/oneapi/compiler/latest/linux/bin/intel64:/root//apps/oneapi/compiler/latest/linux/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin 
 export LD_LIBRARY_PATH=$MPI_DIR/lib:/opt/intel/oneapi/compiler/latest/lib:/opt/intel/oneapi/compiler/latest/linux/lib:/opt/intel/oneapi/compiler/latest/linux/lib/x64:/opt/intel/oneapi/compiler/latest/linux/compiler/lib/intel64_lin 
 export LIBRARY_PATH=/opt/intel/oneapi/compiler/latest/lib:/opt/intel/oneapi/compiler/latest/linux/compiler/lib/intel64_lin:/opt/intel/oneapi/compiler/latest/linux/lib 
 pwd 
 apt-get -y update 
 apt-get -y install -y tzdata git moreutils curl wget rsync  sudo ca-certificates 
 echo ca_certificate=/etc/ssl/certs/ca-certificates.crt >  ~/.wgetrc 
 echo        "cacert=/etc/ssl/certs/ca-certificates.crt" >> ~/.curlrc 
 if [ $(echo $FC | cut -c -8) = gfortran ]; then
     apt-get -y install -y  ${FC}
 fi
 pwd 
 echo '@@ ls -lart ' 
 ls -lart  
 echo '@@ ls on /opt' 
 ls -lart /opt 
 echo " ==========" 
 pwd 
 apt-get -y install -y   tar libnl-3-200 libnl-route-3-200 libgomp1 libnuma1 \
 g++ gfortran   make ssh patch   unzip perl-base file \
 python3 python3-dev python-is-python3 cmake  unzip zip perl automake libtool autoconf flex  \
 libnuma-dev libslurm-dev \
 libnl-3-dev  libnl-route-3-dev udev \
 librdmacm-dev librdmacm1 rdma-core libibverbs-dev  ibverbs-providers  \
 libhwloc-dev libfuse3-dev\
 libconfig-dev libsensors-dev libuv1-dev libfuse-dev libyaml-dev libjson-c-dev libcurl4-openssl-dev  \
 libevdev-dev libevent-dev lmod \
 pkg-config gawk  software-properties-common 
 if [ $ompi_major = '4' ] || [ $mpich_major = '3' ] || [ $mpich_major = '4' ]; then
    apt-get -y install -y libpmi2-0-dev libpmi0-dev
fi 
 if [ $mpich_major = '5' ] || [ $ompi_major = '5' ]; then
    apt-get -y install -y libpmix-bin libpmix-dev libpmix2
fi 
 export GCC_VERSION=11 
 add-apt-repository -y ppa:ubuntu-toolchain-r/test && apt-get update 
 apt-get install -q=2 -y  gcc-"$GCC_VERSION"  g++-"$GCC_VERSION" gfortran-"$GCC_VERSION" libgfortran-"$GCC_VERSION"-dev bzip2 gnupg2
 update-alternatives --install /usr/bin/gcc gcc /usr/bin/gcc-"$GCC_VERSION" 100
 update-alternatives --install /usr/bin/g++ g++ /usr/bin/g++-"$GCC_VERSION" 100
 update-alternatives --install /usr/bin/gfortran gfortran /usr/bin/gfortran-"$GCC_VERSION" 100
 apt-get clean
 echo TTTTT
 df -h
 bash -o  pipefail -c  ./nwchem/travis/build_env.sh || true
 echo TTTTT
 echo "PATH" $PATH
 echo "LD_LIBRARY_PATH" $LD_LIBRARY_PATH 
 echo FFFFF 
 echo 'FC -v ' `$FC -v` 
 echo ' CC is ' "$CC" 
 echo ' CXX is ' "$CXX" || true

if [ $CUDA_CC != "cpu" ]; then
export ELPA_NVIDIA=1
export CUDA_VERSION_MAJOR=12 ; export CUDA_VERSION_MINOR=6
 curl -LJO https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2404/x86_64/cuda-archive-keyring.gpg
  cp cuda-archive-keyring.gpg /usr/share/keyrings/cuda-archive-keyring.gpg
  echo 'deb [signed-by=/usr/share/keyrings/cuda-archive-keyring.gpg] https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2404/x86_64/ /' |  tee /etc/apt/sources.list.d/cuda-ubuntu2404-x86_64.list
  curl -LJO https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2404/x86_64/cuda-ubuntu2404.pin
  mv cuda-*.pin /etc/apt/preferences.d/cuda-repository-pin-600
  apt-get  update
  apt-get  -y install cuda-nvcc-${CUDA_VERSION_MAJOR}-${CUDA_VERSION_MINOR} cuda-cudart-dev-${CUDA_VERSION_MAJOR}-${CUDA_VERSION_MINOR} cuda-libraries-${CUDA_VERSION_MAJOR}-${CUDA_VERSION_MINOR} cuda-libraries-dev-${CUDA_VERSION_MAJOR}-${CUDA_VERSION_MINOR} libcublas-dev-${CUDA_VERSION_MAJOR}-${CUDA_VERSION_MINOR} cuda-libraries-${CUDA_VERSION_MAJOR}-${CUDA_VERSION_MINOR} cuda-nvml-dev-${CUDA_VERSION_MAJOR}-${CUDA_VERSION_MINOR} \
 libnccl-dev
#figure out CUDA_RUNTIME
export CUDA_ROOT=/usr/local/cuda-${CUDA_VERSION_MAJOR}.${CUDA_VERSION_MINOR}
export PATH=${CUDA_ROOT}/bin:$PATH
echo ls cudaroot/bin $(ls -lart ${CUDA_ROOT}/bin)
export LD_LIBRARY_PATH=${CUDA_ROOT}/lib64:"$LD_LIBRARY_PATH" 
echo "ls cuda rt available" $(ls ${CUDA_ROOT}/lib64/libcu*) || true
CUDA_RUNTIME=$(nvcc --version |grep Cuda\ compilation | cut -d " " -f 5|sed -e s'/,//')
echo gpu archs available $(nvcc --list-gpu-arch)
echo CUDA_RUNTIME is $CUDA_RUNTIME
#need to add nvcc compiler flags option  -arch=sm_${CUDA_CC}
export NVCC_APPEND_FLAGS=-arch=sm_${CUDA_CC}
echo "looking for libcuda.so" $(find $CUDA_ROOT -name libcuda.so)
 dpkg-query -Wf '${Installed-Size}\t${Package}\n' | sort -n | tail -n 100 
 apt-get clean
fi
     
export ORGPWD=$(pwd)
echo ORGPWD is $ORGPWD
if [ $UCX != "N" ]; then
    echo check ucx install 
    echo 'ls -l /opt/mpi/lib/libuct.so' $(ls -l /opt/mpi/lib/libuct.so) || true 
    if [ ! -f /opt/mpi/lib/libuct.so ]; then  
	$FC -v 
	wget --progress=dot:giga  https://github.com/openucx/ucx/releases/download/$UCXVTAG/ucx-$UCX.tar.gz -O - | tar xzf - 
	cd ucx-$UCX 
	wget https://raw.githubusercontent.com/edoapra/nwchem-singularity/master/nwchem-dev.ompi41x.ifx/ucx_malloc.patch 
	wget https://raw.githubusercontent.com/edoapra/nwchem-singularity/master/nwchem-dev.ompi5x/ucx1181_malloc.patch 
	if [ $UCX = 1.14.1 ] || [ $UCX = 1.15.0 ]; then
	    patch -p0 < ./ucx_malloc.patch
	else
	    patch -p0 < ./ucx1181_malloc.patch
	fi 
	mkdir build && cd build 
	../configure --prefix=$MPI_DIR --disable-logging --disable-debug --disable-assertions --disable-params-check || { echo "UCX config Failure"; exit 1; }
	make -j4 || { echo "UCX Compilation Failure"; exit 1; }
	make install || { echo "UCX Installation Failure"; exit 1; }
	if [ ! -f $MPI_DIR/bin/ucx_info ]; then echo ucx_info\ not\ found ; exit 1 ; fi 
	cd $ORGPWD
    else
	echo "using UCX cached installtation"
    fi
    echo ' check ucx' 
    if [ ! -f $MPI_DIR/bin/ucx_info ]; then echo ucx_info\ not\ found ; exit 1 ; fi 
    echo ' /opt/mpi/bin/ucx_info -v ' `/opt/mpi/bin/ucx_info -v|| true` 
    echo ' ucx Transports' `/opt/mpi/bin/ucx_info  -d |grep Transport |cut -c 19- || true` 
fi
if [ $OFI != "N" ]; then
    #install cxi
    echo 'ls -l /opt/mpi/shs-cassini-headers/cray-cassini-headers-public.spec' $(ls -l /opt/mpi/shs-cassini-headers/cray-cassini-headers-public.spec) || true 
    if [ ! -f /opt/mpi/shs-cassini-headers/cray-cassini-headers-public.spec ]; then  
	cd / ; ls -lrta  
	mkdir -p $MPI_DIR  
	cd $MPI_DIR
	export SHSTAG=release/shs-12.0.2
	wget --progress=dot:giga https://github.com/HewlettPackard/shs-cassini-headers/archive/refs/heads/main.tar.gz -O - | tar xzf -
	mv shs-cassini-headers* shs-cassini-headers
#	git clone --branch $SHSTAG https://github.com/HewlettPackard/shs-cxi-driver
	wget https://github.com/HewlettPackard/shs-cxi-driver/archive/refs/tags/${SHSTAG}.tar.gz -O - |tar xzf -
	mv shs-cxi-driver* shs-cxi-driver
	cd $ORGPWD
	wget --progress=dot:giga https://github.com/HewlettPackard/shs-libcxi/archive/refs/tags/${SHSTAG}.tar.gz -O - | tar xzf -
	mv shs-libcxi-* shs-libcxi
	cd shs-libcxi 
	sh autogen.sh 
	./configure --prefix=$MPI_DIR 
	make CFLAGS=-I$MPI_DIR/shs-cassini-headers/include/\ -I$MPI_DIR/shs-cxi-driver/include/ pkg_CFLAGS=-Wall -i 
	make CFLAGS=-I$MPI_DIR/shs-cassini-headers/include/\ -I$MPI_DIR/shs-cxi-driver/include/ install-dist_cxi_yamlDATA install-man install-pkgconfigDATA install-pkgincludeHEADERS  install-exec   
	export libfabric_options=--enable-cxi=$MPI_DIR\ --with-cassini-headers=$MPI_DIR/shs-cassini-headers\ --with-cxi-uapi-headers=$MPI_DIR/shs-cxi-driver
	echo 'libfabric_options are' $libfabric_options
	rm -rf shs-*
    fi
    cd  $ORGPWD
    #install OFI
    echo 'ls -l /opt/mpi/lib/libfabrics.so' $(ls -l /opt/mpi/lib/libfabrics.so) || true 
    if [ ! -f /opt/mpi/lib/libfabrics.so ]; then  
	if [ ${OFI} = builtin ]; then
	    echo 'using builtin OFI - nothing to download'
	else
	    if [ ${OFI} = git ]; then
		export COMMIT=c3420a7402a10f5fe3f475ac5eb39b3f2837f8d1
		wget  --progress=dot:giga https://github.com/ofiwg/libfabric/archive/$COMMIT.tar.gz -O - | tar --no-same-owner xzf -
		ls -lrt 
		mv libfabric-$COMMIT libfabric-git 
		cd libfabric-git && sh autogen.sh;
		apt-get install -y libconfig-dev libsensors-dev libuv1-dev libfuse-dev libyaml-dev libjson-c-dev libcurl4-openssl-dev  
	    else
		wget --progress=dot:giga  https://github.com/ofiwg/libfabric/releases/download/v$OFI/libfabric-$OFI.tar.bz2 -O - | tar --no-same-owner  -xjf -
		#	    export libfabric_options=' '
	    fi 
	    cd  $ORGPWD ; echo 'pwd ' $(pwd) ;ls -lrta 
	    cd libfabric-${OFI}
	    mkdir build && cd build 
	    ../configure --prefix=$MPI_DIR $libfabric_options || { echo "OFI configuration Failure"; exit 1; }
	    make -j4 || { echo "OFI Compilation Failure"; exit 1; }
	    make install || { echo "OFI Installation Failure"; exit 1; }
	    if [ ! -f $MPI_DIR/bin/fi_info ]; then echo fi_info\ not\ found ; exit 1 ; fi 
	fi 
	cd .. 
	rm -rf libfabr* 
    fi
fi
echo ucx_or_ofi is $ucx_or_ofi
cd $ORGPWD
if [ $PMIX != "N" ]; then
    if [ ! -f /opt/mpi/lib/libpmix.so ]; then
	wget https://github.com/openpmix/openpmix/releases/download/v${PMIX}/pmix-${PMIX}.tar.gz 
	tar xzf pmix-${PMIX}.tar.gz 
	cd pmix-${PMIX} 
	./configure --prefix=${MPI_DIR} || { echo "PMIX configuration Failure"; exit 1; }
	make -j3 || { echo "PMIX Compilation Failure"; exit 1; }
	make -j3 install || { echo "PMIX installation Failure"; exit 1; }
	cd .. 
	rm -rf pmix-*.*
    fi
fi
