	make FC=$FC -j 6  || { echo "OMPI Compilation Failure"; exit 1; }
	make install      || { echo "OMPI Installation Failure"; exit 1; }
	if [ ! -f $MPI_DIR/bin/mpif90 ]; then echo mpif90\ not\ found ; exit 1 ; fi 
	echo mpif90 show is $($MPI_DIR/bin/mpif90 -show) 
