    wget --progress=dot:giga https://github.com/Cray-HPE/xpmem/tarball/master -O xpmem.tar.gz 
    tar xzf xpmem.tar.gz 
    rm xpmem.tar.gz 
    cd Cray-HPE-xpmem* 
    sh autogen.sh 
    ./configure --prefix=$MPI_DIR --disable-kernel-module  || { echo "XPMEM Configuration Failure"; exit 1; }
    make -j3 || { echo "XPMEM Compilation Failure"; exit 1; }
    make install || { echo "XPMEM Installation Failure"; exit 1; }
fi
cd $ORGPWD
if [ -n "${OMPI+1}" ]; then
    echo check ompi install 
    echo 'ls -l /opt/mpi/lib/libmpi.so' $(ls -l /opt/mpi/lib/libmpi.so) || true 
    if [ ! -f /opt/mpi/lib/libmpi.so ]; then
	wget  --progress=dot:giga https://download.open-mpi.org/release/open-mpi/v$ompi_major.$ompi_minor/openmpi-$OMPI.tar.gz  -O - | tar xzf -
	cd $ompi_prefix                                                       
	./configure  --prefix=${MPI_DIR} \
	$ucx_or_ofi   \
		     $ompi_options \
		     --with-xpmem=$MPI_DIR \
		     $pmix_otions \
		     --enable-mpi1-compatibility --with-slurm --without-tm --without-lsf  \
		     --without-sge --without-lustre --disable-memchecker \
		     --without-hcoll --disable-static  \
		     --disable-mpi-java --enable-dlopen --without-cuda  \
		     FC=$FC || { echo "OMPI config Failure"; exit 1; }
